%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CO2 (NO-VIB) CONFIGURATION FILE LOKI-GM %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% --- configuration of the working conditions ---
workingConditions:
  reducedField: 41                          % in Td
  electronTemperature: 2.513532058742565    % in eV
  excitationFrequency: 0                    % in Hz
  gasPressure: 133.332                      % in Pa
  gasTemperature: 423.014815                % in K   (average gas temperature)
  nearWallTemperature: 323.15
  wallTemperature: 323.15                   % in K   (wall temperature)
  extTemperature: 300                       % in K   (external temperature)
  surfaceSiteDensity: 1e19                  % in m-2 (used for surface kinetics)
  electronDensity: 3.89e15                  % in m-3
  chamberLength: 0.67                       % in m
  chamberRadius: 0.01                       % in m
  % dischargeCurrent: 30*1e-3                 % in A
  % dischargePowerDensity: 1e6                % in W m-3  
  totalSccmInFlow: 7.4                      % in sccm
  totalSccmOutFlow: ensureIsobaric          % a number (in sccm) or a model: totalSccmInFlow, ensureIsobaric

% --- configuration of the electron kinetics ---
electronKinetics:
  isOn: true                                % true or false (to activate of deactivate the electron Kinetics)
  eedfType: boltzmann                       % boltzmann or prescribedEedf (generalized expression Maxwellian/Druyvesteyn)
  % shapeParameter: 1                         % prescribedEedf shape parameter from 1 (Maxwellian) to 2 (Druyvesteyn)
  ionizationOperatorType: usingSDCS         % conservative, oneTakesAll, equalSharing or usingSDCS
  growthModelType: temporal                 % temporal or spatial
  includeEECollisions: false                % true or false (to include or not the effect of e-e collisions on the EEDF)
  LXCatFiles:
    - Oxygen/O2_LXCat.txt
    - Oxygen/O_LXCat.txt
    - CO2/CO2_LXCat.txt
    - CO/CO_LXCat.txt
    - CO/CO_rot_LXCat.txt    
  CARgases:                                 % gases for which CAR is activated
    - O2
  LXCatFilesExtra:                          % extra cross section files
    - Oxygen/O2_LXCat_extra.txt
    - Oxygen/O_LXCat_extra.txt
    - Oxygen/O3_LXCat_extra.txt
    - CO2/CO2_LXCat_extra.txt
    - CO/CO_LxCat_extra.txt
  % effectiveCrossSectionPopulations:         % see doc
  %   - CO2/CO2_effectivePop.txt    
  gasProperties:                            % properties of the gases (S.I. Units)
    mass: Databases/masses.txt
    fraction:
      - O2 = 0.01   
      - O = 0.01
      - CO2 = 0.97  
      - CO = 0.01   
    harmonicFrequency: Databases/harmonicFrequencies.txt
    anharmonicFrequency: Databases/anharmonicFrequencies.txt
    rotationalConstant: Databases/rotationalConstants.txt
    electricQuadrupoleMoment: Databases/quadrupoleMoment.txt
    OPBParameter: Databases/OPBParameter.txt
  stateProperties:                      % properties of the states (S.I. Units except for the energy [eV])
    energy:
      - Oxygen/O2_vib_energy_levels.txt
      - CO/energyVibLevCOX.txt
      - CO2/energyVibLevCO2X.txt
      - CO(X,v=*) = harmonicOscillatorEnergy 
      - CO(X,v=0,J=*) = rigidRotorEnergy  
    statisticalWeight:
      - O2(X) = 3
      - O2(a1Dg) = 2 
      - O2(b1Sg+) = 1
      - O2(A3Su+_C3Du_c1Su-) = 10
      - O2(X,v=*) = 3
      - O(3P) = 9
      - O(1D) = 5
      - O(1S) = 1 
      - CO2/statWeightCO2X.txt
      - CO(X) = 1.0
      - CO(X,v=*) = 1.0
      - CO(a3P) = 6
      - CO(X,v=0,J=*) = rotationalDegeneracy
    population:
      - O2(X) = 1.0
      - O2(X,v=*) = boltzmannPopulation@gasTemperature 
      - O(3P) = 1.0
      - CO2(X) = 1.0
      - CO2(X,v=000) = 1
      - CO(X) = 1.0
      - CO(X,v=*) = boltzmannPopulation@gasTemperature
      - CO(X,v=0,J=*) = boltzmannPopulation@gasTemperature
  numerics:                             % configuration of numerical details of the simulation
    energyGrid:                         % properties of the energy grid (in eV)
      maxEnergy: 50                     % (use 18-20 for time-dependent simulations)
      cellNumber: 2000                  % (use 1800-2000 for time-dependent simulations)
      smartGrid:                        % configuration of the smart grid
        minEedfDecay: 20                % minimum number of decade-fall for the EEDF
        maxEedfDecay: 25                % maximum number of decade-fall for the EEDF
        updateFactor: 0.2               % factor used to increase or decrease the maximum value of the energy grid
    maxPowerBalanceRelError: 1e-9       % threshold for the relative power balance warning message (use at least 100 for time dependent simulations)
    nonLinearRoutines:
      algorithm: mixingDirectSolutions  % mixingDirectSolutions or temporalIntegration
      mixingParameter: 1                % mixingDirectSolutions mixing parameter from 0 to 1
      maxEedfRelError: 1e-10            % maximum rel. variation for EEDF between two iterations (stop criterion)
      % odeSetParameters:                 % optional parameters for the ode solver of the "temporalIntegration" algorithm
      %   AbsTol: 1e-300
      %   RelTol: 1e-6
      %   MaxStep: 1e-7

% --- configuration for the heavy species kinetics ---
chemistry:
  isOn: true
  convergenceParameter: electronDensity % electronDensity or dischargeCurrent or dischargePowerDensity 
  thermalModel:
    isOn: false                         % true or false (to activate or deactivate the thermal model)
    boundary: wall                      % wall or external (location of the model boundary condition)
    wallFraction: 1                     % fraction of energy released at the wall that returns to the gas/plasma volume (check fw parameter in the documentation)
    intConvCoeff: 120/1.6021766208e-19  % in eV s-1 m-2 K-1 (internal convection coefficient of the cylindrical wall)
    extConvCoeff: 15/1.6021766208e-19   % in eV s-1 m-2 K-1 (external convection coefficient of the cylindrical wall)
    includeJouleHeating: false
  chemFiles: 
    - Oxygen/oxygen_novib.chem
    - CO2/CO2_novib.chem
    - CO/CO_simple_X.chem
  checkChemFilesStoichiometry: false    % true or false (to activate or deactivate stoichiometry check in chem files)        
  gasProperties:                        % inherited from the configuration of the electron kinetics
    inFlowFraction: 
      - CO2 = 1
    lennardJonesDistance: Databases/lennardJonesDistance.txt
    lennardJonesDepth: Databases/lennardJonesDepth.txt
  stateProperties:
    reducedMobility:
      - O(+,gnd) = tableEoNDependentMobility@Databases/IonMobilities/O+_O2.txt
      - O2(+,X) = tableEoNDependentMobility@Databases/IonMobilities/O2+_O2.txt
      - O(-,gnd) = tableEoNDependentMobility@Databases/IonMobilities/O-_O2.txt
      - CO2(+,X) = 1.1e-4*101324.72/(273*1.38064852e-23) %guess
      - CO(+,X) = 1.8e-4*101324.72/(273*1.38064852e-23) %guess
    reducedDiffCoeff:
      - O2(+,X) = temperatureDependentEinsteinDiffCoeff@gasTemperature
      - O(+,gnd) = temperatureDependentEinsteinDiffCoeff@gasTemperature
      - CO2(+,X) = generalizedTemperatureDependentCoeff@1.5e20/sqrt(273),gasTemperature,0.5 %guess
      - CO(+,X) = generalizedTemperatureDependentCoeff@1.5e20/sqrt(273),gasTemperature,0.5 %guess
    energy:
      - O2(X) = 0
      - O2(a1Dg) = 0.98
      - O2(b1Sg+) = 1.63
      - O2(A3Su+_C3Du_c1Su-) = 4.5
      - O(3P) = 2.58
      - O(1D) = 4.55
      - O3(X) = 1.48
      - O3(exc) = 1.57
      - O2(+,X) = 12.14
      - O(+,gnd) = 16.26
      - O(-,gnd) = 1.05
    population:
      - O2(*) = 1e-25
      - O2(X) = 1.0
      - O(*) = 1e-25
      - O(3P) = 1.0
      - CO2(*) = 1e-25
      - CO2(X) = 1.0
      - CO(*) = 1e-25
      - CO(X) = 1.0
    inFlowPopulation:
      - CO2(X) = 1 
    % flowBarrier:         % flow barrier (factor between 0-1; by default is set = 1) 
    %   - CO2(*) = 0.05
    %   - CO2(X,v=0) = 0.1                 
  iterationSchemes:                 % set any MaxIterations = 1 to eliminate the corresponding cycle
    % pressureRelError: 1e-3  
    pressureMaxIterations: 1        % set to 1 (to eliminate the pressure cycle) for 'ensureIsobaric' flow model
    % neutralityRelError: 1e-3  
    neutralityMaxIterations: 200 
    % globalRelError: 1e-3    
    globalMaxIterations: 200
  timeIntegrationConf:
    odeSolver: ode15s  
    dischargeTime: 100
    postDischargeTime: 0
    odeSetParameters:               % optional parameters that can be sent to the odeSolver
      MaxStep: 0.1
      RelTol: 5e-4
      % AbsTol: 1e-10
    
% --- configuration of the graphical user interface ---
gui: 
  isOn: true
  refreshFrequency: 1

% ---  configuration of the output files ---
output: 
  isOn: true
  dataFormat: hdf5+txt % txt or hdf5 or hdf5+txt
  folder: simulation_chem_CO2_novib
  dataSets:
%     - inputs
    - log
    - eedf
    - swarmParameters
    - rateCoefficients
    - powerBalance
%     - lookUpTables
    - finalDensities
    - finalParticleBalance
    - chemSolutionTime
    - chemParameters